{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	root * /app/browser

	# Cache immutable pour les assets hashés (JS, CSS) - 1 an
	@hashed path *.js *.css
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# Cache long pour les polices - 1 an
	@fonts path *.woff *.woff2
	header @fonts Cache-Control "public, max-age=31536000, immutable"

	# Cache pour les images et icônes - 1 semaine
	@images path *.avif *.webp *.png *.jpg *.jpeg *.svg *.ico
	header @images Cache-Control "public, max-age=604800, must-revalidate"

	# Pas de cache pour le HTML (SPA)
	@html path *.html /
	header @html Cache-Control "no-cache, must-revalidate"

	file_server {
		hide .git
		hide .env*
	}

	encode {
		gzip
		zstd
	}

	try_files {path} {path}.html {path}/index.html /index.html
}
